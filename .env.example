COOLIFY_BASE_URL=https://coolify.proto-beta.fr
COOLIFY_TOKEN=replace-with-read-only-token
# Required only for /webhooks/github cleanup (delete app + db).
COOLIFY_TOKEN_WRITE=replace-with-write-scoped-token
# Required only for /webhooks/github signature verification.
# Must match what's configured in GitHub org Settings → Webhooks.
GITHUB_WEBHOOK_SECRET=long-random-string
GITHUB_ORG=betagouv-experimentations
PORT=3000
LOG_LINES=200
APP_CACHE_TTL_MS=300000
MEMBERSHIP_CACHE_TTL_MS=300000
